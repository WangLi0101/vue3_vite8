{
  "name": "my-vue-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:dev": "pnpm run typecheck && vite build --mode development",
    "build:staging": "pnpm run typecheck && vite build --mode staging",
    "build:prod": "pnpm run typecheck && vite build --mode production",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "lint:style": "stylelint \"src/**/*.{vue,scss,css}\" \"public/**/*.css\"",
    "lint:style:fix": "stylelint \"src/**/*.{vue,scss,css}\" \"public/**/*.css\" --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "check": "pnpm run typecheck && pnpm run lint && pnpm run lint:style",
    "prepare": "husky"
  },
  "lint-staged": {
    "**/*.{js,mjs,cjs,jsx,ts,mts,cts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "**/*.vue": [
      "eslint --fix",
      "stylelint --fix",
      "prettier --write"
    ],
    "**/*.{scss,css}": [
      "stylelint --fix",
      "prettier --write"
    ],
    "**/*.{json,md,html}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "pinia": "^3.0.3",
    "vue": "^3.5.30",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.0.1",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "@vue/tsconfig": "^0.9.1",
    "autoprefixer": "^10.4.21",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.4",
    "postcss": "^8.5.6",
    "postcss-html": "^1.8.0",
    "postcss-scss": "^4.0.9",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "sass": "^1.90.0",
    "stylelint": "^16.25.0",
    "stylelint-config-standard-scss": "^16.0.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.0",
    "vite-plugin-mock": "^3.0.2",
    "vite-svg-loader": "^5.1.1",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.0.6"
  }
}
